# ElevenLabs Text-to-Speech Configuration
# Get your API key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice ID
# Find voice IDs at: https://elevenlabs.io/app/voice-lab
# Default: mDYJ5aI19GeZeL0uKqb3 (Rachel voice)
ELEVENLABS_VOICE_ID=mDYJ5aI19GeZeL0uKqb3

# ElevenLabs Model ID
# Options: eleven_multilingual_v2, eleven_monolingual_v1, eleven_turbo_v2, etc.
# Default: eleven_multilingual_v2
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
